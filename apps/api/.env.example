# ==============================================================================
# AsyncHub API Configuration Example
# ==============================================================================

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# The secret key is used to sign JWT tokens. 
# GENERATE YOUR OWN with: `openssl rand -hex 32`
SECRET_KEY=replace_this_with_a_secure_random_string

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/dbname
# E.g., for local Docker Compose: postgresql+asyncpg://postgres:postgres@postgres:5432/asynchub
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asynchub

# ------------------------------------------------------------------------------
# Optional Services
# ------------------------------------------------------------------------------
# Redis URL (Optional for v1, used for caching/pubsub later)
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# CORS settings
# ------------------------------------------------------------------------------
# List of origins allowed to make requests (e.g., ["http://localhost:3000"])
BACKEND_CORS_ORIGINS=["*"]
